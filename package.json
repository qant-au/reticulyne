{
  "name": "@qant-au/isoflow",
  "version": "4.1.1",
  "private": false,
  "description": "An open-source React component for drawing network diagrams.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qant-au/isoflow.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/",
    "access": "restricted"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/Isoflow.d.ts",
  "exports": {
    ".": {
      "types": "./dist/Isoflow.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./standalone": {
      "types": "./dist/standaloneExports.d.ts",
      "import": "./dist/standaloneExports.js",
      "require": "./dist/standaloneExports.js",
      "default": "./dist/standaloneExports.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "*.css",
    "**/GlobalStyles.*"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "webpack serve --config ./webpack/dev.config.js",
    "dev": "nodemon --watch ./src/ -e ts,tsx --exec npm run build",
    "clean": "rm -rf dist dist-docker dist-docker-examples",
    "build": "npm run clean && webpack --config ./webpack/prod.config.js && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "lint": "tsc --noEmit && eslint ./src",
    "lint:fix": "eslint --fix ./src",
    "docker:build": "rm -rf dist-docker && webpack --config ./webpack/docker.config.js",
    "docker:examples:build": "rm -rf dist-docker-examples && webpack --config ./webpack/docker-examples.config.js"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eslint/js": "^9.39.4",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/chroma-js": "^3.1.2",
    "@types/file-saver": "^2.0.7",
    "@types/jest": "^29.5.14",
    "@types/pathfinding": "^0.0.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/webpack-env": "^1.18.8",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jsdom": "^29.1.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.4",
    "webpack-merge": "^5.8.0",
    "zustand": "^5.0.13"
  },
  "dependencies": {
    "chroma-js": "^3.2.0",
    "file-saver": "^2.0.5",
    "gsap": "^3.15.0",
    "html-to-image": "^1.11.13",
    "immer": "^11.1.8",
    "jspdf": "^4.2.1",
    "pathfinding": "^0.4.18",
    "react-quill-new": "^3.8.3",
    "uuid": "^11.1.1",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "react": ">=18",
    "react-dom": ">=18",
    "zustand": "^5.0.13"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
