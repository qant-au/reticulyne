{
  "name": "isoflow",
  "version": "1.1.1",
  "private": false,
  "description": "An open-source React component for drawing network diagrams.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/markmanx/isoflow.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/Isoflow.d.ts",
  "scripts": {
    "start": "webpack serve --config ./webpack/dev.config.js",
    "dev": "nodemon --watch ./src/ -e ts,tsx --exec npm run build",
    "build": "webpack --config ./webpack/prod.config.js && tsc --declaration --emitDeclarationOnly && tsc-alias",
    "test": "jest",
    "lint": "tsc --noEmit && eslint ./src/**/* --ext .ts,.tsx",
    "lint:fix": "eslint --fix ./src/**/* --ext .ts,.tsx",
    "docker:build": "webpack --config ./webpack/docker.config.js"
  },
  "devDependencies": {
    "@isoflow/isopacks": "^0.0.10",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/chroma-js": "^2.4.5",
    "@types/dom-to-image": "^2.6.7",
    "@types/file-saver": "^2.0.7",
    "@types/jest": "^27.5.2",
    "@types/jsdom": "^21.1.7",
    "@types/pathfinding": "^0.0.6",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^9.0.8",
    "@types/webpack-env": "^1.18.8",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "concurrently": "^7.6.0",
    "css-loader": "^6.11.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^17.1.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^21.1.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4",
    "style-loader": "^3.3.4",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^5.9.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.2"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^5.18.0",
    "@mui/material": "^5.18.0",
    "react-quill-new": "^3.8.3",
    "auto-bind": "^5.0.1",
    "chroma-js": "^2.6.0",
    "dom-to-image": "^2.6.0",
    "file-saver": "^2.0.5",
    "gsap": "^3.15.0",
    "immer": "^10.2.0",
    "mui-color-input": "^2.0.3",
    "paper": "^0.12.18",
    "pathfinding": "^0.4.18",
    "react-hook-form": "^7.76.0",
    "react-router-dom": "^6.30.3",
    "uuid": "^9.0.1",
    "zod": "3.22.2",
    "zustand": "^4.5.7"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
