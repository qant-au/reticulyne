{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "declaration": true,
    "emitDeclarationOnly": true
  },
  "exclude": [
    "node_modules",
    "./dist",
    "./dist-docker",
    "./docs",
    "src/index.tsx",
    "src/index-docker.tsx",
    "src/examples/**",
    "src/fixtures/**",
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
